{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "welldone-services-company",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "routes": [
    {
      "pattern": "welldonescompany.com",
      "custom_domain": true
    },
    {
      "pattern": "www.welldonescompany.com",
      "custom_domain": true
    }
  ]
}
